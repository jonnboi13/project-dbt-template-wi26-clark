         as
        (SELECT DISTINCT
    CAST(DATETIME AS DATE) AS CALENDAR_DATE,
    DAY(CAST(DATETIME AS DATE)) AS DAY_NUM_IN_MONTH,
    DAYNAME(CAST(DATETIME AS DATE)) AS DAY_NAME,
    DAYOFWEEK(CAST(DATETIME AS DATE)) AS DAY_OF_WEEK_NUM,
